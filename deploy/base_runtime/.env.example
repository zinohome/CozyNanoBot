# CozyNanoBot Base Runtime — 环境变量模板
# 用法：cp .env.example .env 后填充真实值。.env 已被 gitignore。

# ============= LLM Provider =============
# OpenAI（或 OpenAI-compatible 代理，如 oneapi）
OPENAI_API_KEY=sk-REPLACE-ME

# 可选：若用 OpenAI-compatible 代理，在 config/nanobot.yaml 的 providers 段配 base_url；
# nanobot 本身通过 provider 配置读取，这里保留环境变量作为插值来源。
# OPENAI_BASE_URL=https://oneapi.naivehero.top/v1

# ============= nanobot 配置 =============
# 覆盖镜像内默认 config 路径；通常不需要改
# NANOBOT_CONFIG=/app/config/nanobot.yaml
