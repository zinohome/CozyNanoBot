# CozyNanoBot Base Runtime — 环境变量模板
# 用法：cp .env.example .env 后填充真实值。.env 已被 gitignore。

# ============= LLM Provider =============
# OpenAI（或 OpenAI-compatible 代理，如 oneapi）
OPENAI_API_KEY=sk-REPLACE-ME

# 可选：OpenAI-compatible 代理 base_url（如 oneapi）
# docker-compose 会把它桥到 NANOBOT_PROVIDERS__OPENAI__API_BASE
OPENAI_BASE_URL=

# ============= nanobot 配置 =============
# 覆盖镜像内默认 config 路径；通常不需要改
# NANOBOT_CONFIG=/app/config/nanobot.yaml
