# CozyNanoBot — 环境变量模板
# 用法：cp .env.example .env 并填充实际值。.env 已被 gitignore。

# ============= LLM Provider =============
# OpenAI（或 OpenAI-compatible 代理，如 oneapi）
OPENAI_API_KEY=sk-REPLACE-ME

# 可选：OpenAI-compatible 代理 base_url
# OPENAI_BASE_URL=https://oneapi.naivehero.top/v1

# ============= nanobot 配置 =============
# 可选：指向自定义 nanobot 配置文件，默认 config/nanobot.yaml
# NANOBOT_CONFIG=config/nanobot.yaml

# ============= 服务端口 =============
# HOST=0.0.0.0
# PORT=8080
